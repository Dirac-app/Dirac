# ============================================================
# Dirac Environment Variables
# ============================================================
# Copy this file to .env.local and fill in the values
# ============================================================

# ------------------------------------------------------------
# Required: Auth & Security
# ------------------------------------------------------------

# NextAuth.js configuration
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000

# Admin authentication
ADMIN_SECRET=your-admin-secret-here

# Tester JWT authentication
TESTER_JWT_SECRET=your-tester-jwt-secret-here

# ------------------------------------------------------------
# Required: Database
# ------------------------------------------------------------

# Supabase (get from Supabase dashboard > Settings > API)
# These are your project-specific values
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ------------------------------------------------------------
# Required: OAuth Providers
# ------------------------------------------------------------

# Google OAuth (get from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Microsoft Azure / Outlook (get from Azure Portal)
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret

# Discord (get from Discord Developer Portal)
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
DISCORD_BOT_TOKEN=your-discord-bot-token

# ------------------------------------------------------------
# Required: AI
# ------------------------------------------------------------

# OpenRouter API Key (get from openrouter.ai)
OPENROUTER_API_KEY=your-openrouter-api-key

# ------------------------------------------------------------
# Optional: App Configuration
# ------------------------------------------------------------

# Base URL (used for OAuth callbacks)
# AUTH_URL=http://localhost:3000
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Public mode - if set to "true", anyone can access without invite
# NEXT_PUBLIC_PUBLIC_MODE=true
