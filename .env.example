# ════════════════════════════════════════════════════════════════════════════════
# Dirac — Environment Variables
# Copy this file to .env.local and fill in the values before running the app.
# Variables marked [REQUIRED] must be set; [OPTIONAL] have safe defaults.
# ════════════════════════════════════════════════════════════════════════════════


# ── Auth (next-auth) ──────────────────────────────────────────────────────────
# [REQUIRED] Random secret used to sign session cookies.
#   Generate: openssl rand -base64 32
#   Type: string (32+ bytes, base64)
NEXTAUTH_SECRET=

# [REQUIRED] Public URL of your deployment (no trailing slash).
#   Used by next-auth to build redirect URLs.
#   Type: URL string
#   Local:      http://localhost:3000
#   Production: https://your-domain.com
NEXTAUTH_URL=http://localhost:3000


# ── Google OAuth (Gmail) ──────────────────────────────────────────────────────
# [REQUIRED for Gmail] OAuth 2.0 credentials from Google Cloud Console.
#   How to get:
#     1. Go to https://console.cloud.google.com → APIs & Services → Credentials
#     2. Create an OAuth 2.0 Client ID (Web application)
#     3. Add authorised redirect URI: <NEXTAUTH_URL>/api/auth/callback/google
#     4. Enable the Gmail API at: https://console.cloud.google.com/apis/library/gmail.googleapis.com
#   Required scopes: openid, email, profile, gmail.readonly, gmail.send, gmail.modify
#   Type: string
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# ── Microsoft OAuth (Outlook / Exchange) ──────────────────────────────────────
# [OPTIONAL] Required only if you want Outlook/Exchange support.
#   How to get:
#     1. Go to https://portal.azure.com → Azure Active Directory → App registrations
#     2. Create a new registration (Accounts in any org directory + personal)
#     3. Add a redirect URI (Web): <NEXTAUTH_URL>/api/oauth/outlook/callback
#     4. Under "Certificates & secrets" create a new client secret
#     5. Under "API permissions" add: User.Read, Mail.Read, Mail.Send,
#        Mail.ReadWrite, offline_access
#   Type: string
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
# Tenant ID — use "common" to support both personal and organisational accounts
# Type: string
AZURE_TENANT_ID=common


# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# [REQUIRED] PostgreSQL connection string.
#   Supported providers: Supabase, Neon, Railway, PlanetScale (Postgres mode),
#   or any self-hosted PostgreSQL 14+ instance.
#   How to get:
#     Supabase: https://app.supabase.com → Project Settings → Database → Connection string
#     Neon:     https://neon.tech → Dashboard → Connection Details
#     Local:    Run `psql` and create a database: CREATE DATABASE dirac;
#   Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
#   Type: URL string
DATABASE_URL=postgresql://postgres:password@localhost:5432/dirac


# ── Supabase (optional — only if using Supabase as your DB host) ──────────────
# [OPTIONAL] These are only needed if you use Supabase's client SDK directly
#   (e.g. for realtime or storage). The app primarily uses DATABASE_URL + Prisma.
#   How to get: https://app.supabase.com → Project Settings → API
#   Type: URL / string
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=


# ── AI (OpenRouter) ───────────────────────────────────────────────────────────
# [OPTIONAL] Server-side API key for AI features (triage, drafts, chat).
#   If omitted, each user must supply their own key in Settings.
#   How to get: https://openrouter.ai → Keys
#   Type: string (starts with "sk-or-")
OPENROUTER_API_KEY=

# [OPTIONAL] Default model slug used when the user has not chosen one.
#   Browse available models at: https://openrouter.ai/models
#   Recommended: google/gemini-2.0-flash-001 (fast + cheap) or
#                anthropic/claude-haiku-4-4    (high quality)
#   Type: string
OPENROUTER_MODEL=google/gemini-2.0-flash-001


# ── Discord (optional) ────────────────────────────────────────────────────────
# [OPTIONAL] Required only if you want Discord DM / channel inbox support.
#   How to get:
#     1. Go to https://discord.com/developers/applications → New Application
#     2. Under "Bot" tab, create a bot and copy the token
#     3. Under "OAuth2" tab, copy Client ID and Secret
#     4. Bot permissions needed: Read Messages/View Channels, Send Messages
#   Type: string
# DISCORD_BOT_TOKEN=
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=


# ── App URL (public) ──────────────────────────────────────────────────────────
# [OPTIONAL] Used internally to build absolute URLs (e.g. Outlook redirect URI).
#   If not set, falls back to NEXTAUTH_URL.
#   Type: URL string
# NEXT_PUBLIC_APP_URL=https://your-domain.com
