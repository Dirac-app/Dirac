# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# Your deployment URL (no trailing slash)
NEXTAUTH_URL=https://your-domain.com

# ── Google OAuth (Gmail) ───────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
# Redirect URI: https://your-domain.com/api/auth/callback/google
# Required APIs: Gmail API
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Microsoft OAuth (Outlook) ──────────────────────────────────────────────────
# Create at: https://portal.azure.com → App registrations
# Redirect URI: https://your-domain.com/api/oauth/outlook/callback
# Required permissions: Mail.Read, Mail.Send, Mail.ReadWrite, offline_access
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=common

# ── Database (PostgreSQL) ──────────────────────────────────────────────────────
# Supports: Supabase, Neon, Railway, or any PostgreSQL instance
DATABASE_URL=postgresql://user:password@host:5432/dirac

# ── Supabase (if using Supabase as your DB host) ───────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── AI (OpenRouter) ────────────────────────────────────────────────────────────
# Get a key at: https://openrouter.ai
# If omitted, users must provide their own key in Settings
OPENROUTER_API_KEY=

# Default model (users can override in Settings)
# See available models at: https://openrouter.ai/models
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# ── Discord (optional) ────────────────────────────────────────────────────────
# Create a bot at: https://discord.com/developers/applications
# Required scopes: bot (with Read Messages, Send Messages permissions)
# DISCORD_BOT_TOKEN=
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
